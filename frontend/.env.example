# Piano Sample Source Configuration
# 钢琴采样源配置

# 采样源类型:
# - official: 使用 Tone.js 官方源 (https://tonejs.github.io/audio/salamander/)
# - self-hosted: 使用自托管源 (/samples/salamander/)
# - custom: 使用自定义 URL (需要配置 VITE_PIANO_SAMPLES_URL)
VITE_PIANO_SAMPLE_SOURCE=official

# 自定义采样源 URL (仅当 VITE_PIANO_SAMPLE_SOURCE=custom 时使用)
# 示例: VITE_PIANO_SAMPLES_URL=https://your-domain.com/samples/salamander/
VITE_PIANO_SAMPLES_URL=
